# =============================================================================
# BudgetLens monorepo — copy values into:
#   frontend/.env.local   (Next.js public env)
#   backend/.env          (FastAPI)
# =============================================================================

# --- Supabase (shared project) ---
# Frontend: use NEXT_PUBLIC_* in frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend: same Supabase project, anon key (no service-role needed — RLS via JWT)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- URLs ---
# Browser-accessible FastAPI base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI: comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
