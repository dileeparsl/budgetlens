# =============================================================================
# BudgetLens monorepo — copy values into:
#   frontend/.env.local   (Next.js public + server env)
#   backend/.env          (FastAPI — never commit real secrets)
# =============================================================================

# --- Supabase (shared project) ---
# Frontend: use NEXT_PUBLIC_* in frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend: use non-prefixed or same URL; service role stays server-only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret from Supabase project API settings (verify Supabase-issued tokens)
SUPABASE_JWT_SECRET=your-jwt-secret

# --- URLs ---
# Next.js app (local + production) — used in Supabase Auth settings
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser-accessible FastAPI base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI: comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
