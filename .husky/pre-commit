#!/bin/sh

# Quick pre-commit checks for hackathon speed
# Fails fast on type errors and lint issues

echo "Running pre-commit checks..."

# Type check (fast)
npx tsc --noEmit --pretty 2>&1 | head -20
if [ $? -ne 0 ]; then
  echo "Type errors found. Fix before committing."
  exit 1
fi

# Lint check (fast)
npm run lint -- --quiet 2>&1 | head -20
if [ $? -ne 0 ]; then
  echo "Lint errors found. Fix before committing."
  exit 1
fi

echo "Pre-commit checks passed!"
